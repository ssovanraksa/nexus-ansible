all:
  children:
    local:
      hosts:
        # VirtualBox host
        local-virtualbox:
          ansible_host: YOUR_HOST_IP
          ansible_connection: ssh
          ansible_user: YOUR_USERNAME
          ansible_port: 22
          ansible_ssh_private_key_file: ./inventory/id_rsa
          # if needed also specify "ansible_ssh_pass: password"
          ansible_become_password: YOUR_PASSWORD